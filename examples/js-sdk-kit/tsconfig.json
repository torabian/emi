{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["es2019", "dom", "dom.iterable"],
    "module": "ESNext",
    "declaration": false,
    "outDir": "build",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": ["src/**/*"]
}
